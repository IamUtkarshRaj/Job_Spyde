# ==========================================
# JobSpyde — Environment Variables Template
# ==========================================
# Copy this file to .env at project root:  cp .env.example .env
# Then fill in your values. This ONE file is used by both web and agent services.
# NEVER commit the actual .env file to version control.

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# === Google Gemini ===
GOOGLE_API_KEY=your-gemini-api-key-here

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USE_SSL=false

# === Agent Service URL (used by Next.js to reach the agent) ===
# Local dev: http://127.0.0.1:8000 | Docker dev: http://agent:8000
NEXT_PUBLIC_AGENT_URL=http://127.0.0.1:8000

# === CORS (comma-separated origins for agent) ===
CORS_ORIGINS=http://localhost:3000

# === Environment ===
ENVIRONMENT=development

# === Supabase Direct DB (Optional — for migrations) ===
# DATABASE_URL=postgresql://...
# DIRECT_URL=postgresql://...

# === Email (Optional) ===
# RESEND_API_KEY=re_...

# === Docker Images (used by docker-compose.prod.yml) ===
GHCR_IMAGE_WEB=ghcr.io/iamutkarshraj/jobspyde-web:latest
GHCR_IMAGE_AGENT=ghcr.io/iamutkarshraj/jobspyde-agent:latest
