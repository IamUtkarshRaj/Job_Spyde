# ==========================================
# JobSpyde — Root .gitignore
# ==========================================

# === Environment & Secrets ===
.env
.env.local
.env.*.local
.env.production
.env.staging
!.env.example

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
ENV/
*.egg-info/
dist/
build/
*.egg

# === Node.js ===
node_modules/
.next/
out/
*.tsbuildinfo
next-env.d.ts
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# === Docker ===
docker-compose.override.yml

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === Debug & Test Artifacts ===
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
coverage/
*.pem
naukri_debug.png
naukri.html
test_curl.txt

# === AI/ML Models (large files) ===
models/
*.pt
*.bin
*.safetensors

# === Agents/Skills (managed separately) ===
.agents/
.claude/
skills-lock.json

# === OS ===
.DS_Store
Thumbs.db
Desktop.ini
